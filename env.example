# Скопируйте в .env в корне репозитория product-mcp

# --- Telegram-бот (обязательно для bot.py) ---
TELEGRAM_API_TOKEN=

# --- OpenAI Chat Completions (обязательно для бота) ---
OPENAI_API_KEY=
# Примеры: gpt-4o-mini, gpt-4o, gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# --- HTTP-интерфейс инструментов MCP (mcp_server/http_api.py) ---
MCP_HTTP_BASE_URL=http://127.0.0.1:8765
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765
# Таймаут HTTP-вызовов из бота (секунды)
MCP_HTTP_TIMEOUT=60
