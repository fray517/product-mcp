{
  "mcpServers": {
    "product-mcp": {
      "type": "stdio",
      "command": "${workspaceFolder}/venv/Scripts/python.exe",
      "args": ["-u", "server.py"],
      "cwd": "${workspaceFolder}/mcp_server",
      "env": {
        "PYTHONUTF8": "1"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  }
}
